`ifndef {{ context.project.name | upper }}_TB_TOP_SV
`define {{ context.project.name | upper }}_TB_TOP_SV

// =============================================================================
// {{ context.project.name }} — Testbench Top
// Generated by BusCraft
// =============================================================================

`include "uvm_macros.svh"
`timescale {{ context.project.global_params.timescale }}

module tb_top;

  import uvm_pkg::*;

  // ---- Clock and Reset ----
  logic {{ context.project.global_params.clock_name }};
  logic {{ context.project.global_params.reset_name }};

  // Clock generation
  initial {{ context.project.global_params.clock_name }} = 0;
  always #5 {{ context.project.global_params.clock_name }} = ~{{ context.project.global_params.clock_name }};  // 100 MHz

  // Reset sequence
  initial begin
{% if context.project.global_params.reset_active_low %}
    {{ context.project.global_params.reset_name }} = 0;  // Assert reset (active low)
    #100;
    {{ context.project.global_params.reset_name }} = 1;  // Deassert reset
{% else %}
    {{ context.project.global_params.reset_name }} = 1;  // Assert reset (active high)
    #100;
    {{ context.project.global_params.reset_name }} = 0;  // Deassert reset
{% endif %}
  end

  // ---- Protocol Interfaces ----
{% for agent in context.agents %}
  {{ agent.protocol_id }}_if {{ agent.name }}_vif (
    .{{ context.project.global_params.clock_name }}({{ context.project.global_params.clock_name }}),
    .{{ context.project.global_params.reset_name }}({{ context.project.global_params.reset_name }})
  );
{% endfor %}

  // ---- DUT Instantiation ----
  // TODO: Replace with your actual DUT module
  // {{ context.project.name }}_dut u_dut (
{% for agent in context.agents %}
  //   .{{ agent.name }}_port({{ agent.name }}_vif){{ "," if not loop.last else "" }}
{% endfor %}
  // );

  // ---- UVM Configuration ----
  initial begin
{% for agent in context.agents %}
    uvm_config_db #(virtual {{ agent.protocol_id }}_if)::set(
      null, "uvm_test_top.m_env.{{ agent.name }}*", "vif", {{ agent.name }}_vif
    );
{% endfor %}

    // Launch UVM test
    run_test();
  end

  // ---- Waveform Dump ----
  initial begin
    $dumpfile("{{ context.project.name }}_waves.vcd");
    $dumpvars(0, tb_top);
  end

endmodule : tb_top

`endif // {{ context.project.name | upper }}_TB_TOP_SV
